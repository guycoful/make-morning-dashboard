                "body": "<!DOCTYPE html>\n<html dir=\"rtl\" lang=\"he\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"margin:0;padding:0;background-color:#f4f4f7;font-family:Arial,Helvetica,sans-serif;direction:rtl\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"background-color:#f4f4f7\">\n    <tr>\n      <td align=\"center\" style=\"padding:24px 16px\">\n        <table role=\"presentation\" width=\"600\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;width:100%;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08)\">\n          <!-- Header -->\n          <tr>\n            <td style=\"background:linear-gradient(135deg,#1B2A4A 0%,#2d3f6b 100%);padding:32px 24px;text-align:center\">\n              <div style=\"font-size:48px;margin-bottom:8px\">\u00f0\u009f\u008e\u0089</div>\n              <h1 style=\"margin:0;color:#ffffff;font-size:24px;font-weight:700\">\u05d9\u05d5\u05dd \u05d7\u05d5\u05e4\u05e9\u05d9!</h1>\n              <p style=\"margin:8px 0 0;color:rgba(255,255,255,0.8);font-size:14px\">{{formatDate(now; \"dddd, DD \u05d1MMMM YYYY\")}}</p>\n            </td>\n          </tr>\n\n          <!-- No Events Message -->\n          <tr>\n            <td style=\"padding:40px 24px;text-align:center\">\n              <div style=\"font-size:48px;margin-bottom:16px\">\u00f0\u009f\u008f\u0096\ufe0f</div>\n              <h2 style=\"margin:0 0 8px;color:#1B2A4A;font-size:20px\">\u05d0\u05d9\u05df \u05e4\u05d2\u05d9\u05e9\u05d5\u05ea \u05d4\u05d9\u05d5\u05dd!</h2>\n              <p style=\"margin:0;color:#666;font-size:16px\">\u05ea\u05ea\u05e2\u05e0\u05d2, \u05d9\u05d5\u05dd \u05e4\u05ea\u05d5\u05d7 \u05dc\u05e2\u05d1\u05d5\u05d3\u05d4 \u05de\u05de\u05d5\u05e7\u05d3\u05ea \u05d0\u05d5 \u05dc\u05de\u05e0\u05d5\u05d7\u05d4 \u05de\u05d6\u05d5\u05de\u05e0\u05ea \u00f0\u009f\u008e\u0089</p>\n            </td>\n          </tr>\n\n          <!-- Tomorrow Preview Section -->\n          {{if(4.text; \"<tr><td style='padding:0 24px 24px'><table role='presentation' width='100%' cellspacing='0' cellpadding='0'><tr><td style='background-color:#f8f7ff;border-radius:8px;padding:16px'><h3 style='margin:0 0 8px;color:#7C3AED;font-size:15px;font-weight:700'>\u00f0\u009f\u0094\u00ae \u05d0\u05d1\u05dc \u05de\u05d7\u05e8 \u05d9\u05e9 \u05dc\u05da:</h3><pre style='margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#555;white-space:pre-wrap;line-height:1.6'>\" + 4.text + \"</pre></td></tr></table></td></tr>\"; \"\")}}\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"padding:16px 24px;background-color:#f9fafb;text-align:center;border-top:1px solid #eee\">\n              <p style=\"margin:0;font-size:12px;color:#999\">\u05e0\u05d5\u05e6\u05e8 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea \u05e2\u05dd Make.com | Guy Cohen AI Agency</p>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
              },
